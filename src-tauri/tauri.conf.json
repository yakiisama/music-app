{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Music",
  "version": "0.1.0",
  "identifier": "com.music.ytplayer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Music",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/yt-dlp", "binaries/ffmpeg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFNEUyQUNDODExQTg0QTkKUldTcGhCcUJ6Q3BPM2wwaU5BOFp2VTJYNnIzdVJKUlcwaW9vYnBQOWNPYVRuMVdTa2F6ZkFzeDgK",
      "endpoints": [
        "https://github.com/yakiisama/music-app/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
